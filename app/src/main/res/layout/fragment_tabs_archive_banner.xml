<!-- ──────────────────────────────────────────────────────────────────── -->
<!-- tabs_archive_banner.xml                                            -->
<!-- Place in res/layout/                                               -->
<!--                                                                    -->
<!-- A dismissible info card shown at the top of TabsFragment when      -->
<!-- inactive tabs have been auto-archived.                             -->
<!-- ──────────────────────────────────────────────────────────────────── -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/archive_banner"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHighest">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Archive icon -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/archive_banner_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_baseline_archive_24"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Title: "X tabs archived" -->
        <TextView
            android:id="@+id/archive_banner_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toEndOf="@id/archive_banner_icon"
            app:layout_constraintEnd_toStartOf="@id/archive_banner_dismiss"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/archive_banner_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.8"
            app:layout_constraintStart_toEndOf="@id/archive_banner_icon"
            app:layout_constraintEnd_toStartOf="@id/archive_banner_dismiss"
            app:layout_constraintTop_toBottomOf="@id/archive_banner_title" />

        <!-- Dismiss button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/archive_banner_dismiss"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:icon="@drawable/ic_baseline_close_24"
            app:iconSize="18dp"
            app:iconTint="?attr/colorOnSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>