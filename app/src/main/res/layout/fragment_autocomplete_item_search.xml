<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_search"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="1dp"
    style="@style/Widget.Material3.CardView.Filled"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MaterialCardView.Top">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_height="@dimen/list_autocomplete_search_height">


        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/icon"
            android:layout_marginStart="12dp"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@null"
            android:src="@drawable/ic_search_24"
            android:tint="?attr/colorOnSurfaceVariant"/>

        <TextView
            android:id="@+id/text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:textAppearance="?android:attr/textAppearanceLargePopupMenu"
            android:text="@string/search_clip"
            style="?attr/textAppearanceTitleMedium"
            android:textSize="16sp" />


    </LinearLayout>

</com.google.android.material.card.MaterialCardView>