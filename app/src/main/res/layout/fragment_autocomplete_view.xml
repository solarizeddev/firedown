<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <include
        android:id="@+id/clipboard_view"
        layout="@layout/fragment_autocomplete_clipboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/address_bar_margin"
        android:layout_marginEnd="@dimen/address_bar_margin"
        android:visibility="gone" />


    <com.solarized.firedown.autocomplete.AutoCompleteRecyclerView
        android:id="@+id/search_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/address_bar_margin"
        android:layout_marginEnd="@dimen/address_bar_margin"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />


</LinearLayout>