<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <View
        android:id="@+id/divider"
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="6dp"
        android:background="@drawable/dialog_rounded_divider" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/host_domain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/host_middle"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/host_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/host"
            style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="marquee"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintBottom_toTopOf="@id/host_middle"
            app:layout_constraintStart_toEndOf="@id/host_image"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="CNN" />

        <TextView
            android:id="@+id/host_url"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/host_image"
            app:layout_constraintTop_toBottomOf="@id/host_middle"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="www.cnn.com" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/ads_middle"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ads_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ads_click_24" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:text="@string/security_ads"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:layout_constraintBottom_toTopOf="@id/ads_middle"
                app:layout_constraintEnd_toStartOf="@id/ads_toogle"
                app:layout_constraintStart_toEndOf="@id/ads_icon" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/ads_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/ads_subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:maxLines="2"
                android:paddingBottom="16dp"
                android:text="@string/security_blocked_in_this_page"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/ads_counter"
                app:layout_constraintStart_toEndOf="@id/ads_icon"
                app:layout_constraintTop_toBottomOf="@id/ads_middle" />


            <TextView
                android:id="@+id/ads_counter"
                style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginEnd="16dp"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:background="@drawable/rounded_primary"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                app:layout_constraintStart_toEndOf="@id/ads_subtext"
                app:layout_constraintTop_toTopOf="@id/ads_subtext"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/tracking_middle"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/tracking_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_shield_24" />

            <TextView
                android:id="@+id/tracking_text"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:text="@string/connection_enhanced_protection"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:layout_constraintBottom_toTopOf="@id/tracking_middle"
                app:layout_constraintEnd_toStartOf="@id/tracking_toogle"
                app:layout_constraintStart_toEndOf="@id/tracking_icon" />

            <TextView
                android:id="@+id/tracking_subtext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingBottom="12dp"
                android:maxLines="2"
                android:text="@string/protection_panel_etp_toggle_enabled_description_2"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/tracking_toogle"
                app:layout_constraintStart_toEndOf="@id/tracking_icon"
                app:layout_constraintTop_toBottomOf="@id/tracking_middle" />


            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/tracking_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/host_secure"
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/host_secure_text"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/list_spacing"
            android:layout_marginEnd="@dimen/list_spacing"
            android:drawablePadding="16dp"
            android:text="@string/connection_secure"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/encryption_light_24" />

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/host_clear"
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/list_spacing"
            android:layout_marginEnd="@dimen/list_spacing"
            android:drawablePadding="16dp"
            android:text="@string/settings_clear_browsing"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_baseline_delete_24" />


    </com.google.android.material.card.MaterialCardView>


</LinearLayout>