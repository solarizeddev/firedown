<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:orientation="horizontal">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/item_tab_selected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="@dimen/list_spacing"
        android:visibility="gone"
        app:srcCompat="@drawable/ic_baseline_check_circle_24" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item_tab"
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="@dimen/list_spacing"
        android:layout_marginEnd="@dimen/list_spacing"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="8dp"
        app:strokeWidth="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/list_margin">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/file_icon"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>


            <TextView
                android:id="@+id/file_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="12dp"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@id/file_more"
                app:layout_constraintStart_toEndOf="@id/file_icon"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/file_url"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/file_name"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                app:layout_constraintStart_toEndOf="@id/file_icon"
                app:layout_constraintEnd_toStartOf="@id/file_more"
                app:layout_constraintTop_toBottomOf="@id/file_name"/>

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/file_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:nextFocusLeft="@id/item_web_bookmark"
                android:padding="6dp"
                android:src="@drawable/ic_baseline_close_24"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>