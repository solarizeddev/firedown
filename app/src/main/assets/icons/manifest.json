{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "icons@mozac.org"
    }
  },
  "name": "Mozilla Android Components - Browser Icons",
  "version": "1",
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["icons.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ]
}
