{
  "author": "Raymond Hill & contributors",
  "background": {
    "page": "background.html"
  },
  "browser_action": {
    "default_title": "uBlock Origin"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "uBlock0@raymondhill.net",
      "strict_min_version": "79.0"
    },
    "gecko_android": {
      "strict_min_version": "79.0"
    }
  },
  "content_scripts": [
    {
      "all_frames": true,
      "js": [
        "/js/vapi.js",
        "/js/vapi-client.js",
        "/js/contentscript.js"
      ],
      "match_about_blank": true,
      "matches": [
        "http://*/*",
        "https://*/*",
        "file://*/*"
      ],
      "run_at": "document_start"
    }
  ],
  "default_locale": "en",
  "description": "__MSG_extShortDesc__",
  "icons": {
    "128": "img/ublock.svg",
    "16": "img/ublock.svg",
    "32": "img/ublock.svg",
    "48": "img/ublock.svg",
    "64": "img/ublock.svg",
    "96": "img/ublock.svg"
  },
  "manifest_version": 2,
  "name": "uBlock Origin",
  "permissions": [
    "alarms",
    "dns",
    "privacy",
    "storage",
    "tabs",
    "geckoViewAddons",
    "unlimitedStorage",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "<all_urls>"
  ],
  "short_name": "uBlock\u2080",
  "version": "1.63.2",
  "web_accessible_resources": [
    "/web_accessible_resources/*"
  ]
}
