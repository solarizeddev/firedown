{
  "manifest_version": 2,
  "version": "1.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube@solarized.dev"
    }
  },
  "name": "Youtube parser",
  "background": {
    "page": "background.html",
    "persistent": false
  },
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "storage",
    "unlimitedStorage",
    "cookies",
    "*://*.googlevideo.com/*",
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://youtubei.googleapis.com/*",
    "*://*.youtube-nocookie.com/*",
    "*://www.google.com/*",
    "https://firedown.app/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*",
        "*://*.youtu.be/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}